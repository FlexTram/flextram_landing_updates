#!/usr/bin/env bash
# Block pushes when the gh CLI active account isn't FlexTram.
#
# Why: this repo pushes to two remotes (FlexTram fork + blackbox-engineering
# production) and both reject pushes from the personal `jmbradley` account.
# git uses gh's active token, so an account drift produces a 403 mid-push.
# Catching it here saves a round-trip.
#
# Bypass (rare, deliberate cases only): `git push --no-verify`.
# Install: `git config core.hooksPath .githooks` (one-time per clone).

if ! command -v gh >/dev/null 2>&1; then
  # gh not installed — assume the contributor has push rights via another path.
  exit 0
fi

current_account=""
active_account=""
while IFS= read -r line; do
  if [[ "$line" =~ Logged\ in\ to\ github\.com\ account\ ([^ ]+) ]]; then
    current_account="${BASH_REMATCH[1]}"
  elif [[ "$line" == *"Active account: true"* ]]; then
    active_account="$current_account"
    break
  fi
done < <(gh auth status 2>&1)

if [ "$active_account" = "FlexTram" ]; then
  exit 0
fi

cat >&2 <<EOF
✗ Push blocked: gh active account is "${active_account:-<none>}", not FlexTram.

Both flextram remotes (origin + production) reject pushes from jmbradley.
Fix:
  gh auth switch --user FlexTram

Then retry the push. To bypass this check intentionally, use --no-verify.
EOF

exit 1
